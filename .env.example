# Copy this file to .env for local testing with `vercel dev` — never commit the real .env file.
# In production, set these as Environment Variables in your Vercel project settings instead.

# From developer.squareup.com/apps -> your app -> Credentials
SQUARE_ACCESS_TOKEN=your-sandbox-or-production-access-token

# From developer.squareup.com/apps -> your app -> Locations (or your Square Dashboard)
SQUARE_LOCATION_ID=your-location-id

# Use "sandbox" while testing, "production" only after approving live payments.
# If omitted on Vercel, the checkout function defaults to sandbox.
SQUARE_ENVIRONMENT=sandbox

# 3-letter currency code matching your Square account/location
SQUARE_CURRENCY=AUD
